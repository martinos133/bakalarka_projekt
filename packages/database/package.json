{
  "name": "@inzertna-platforma/database",
  "version": "1.0.0",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "db:generate": "dotenv -e ../../.env -- prisma generate",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "db:migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "db:studio": "dotenv -e ../../.env -- prisma studio",
    "db:seed": "dotenv -e ../../.env -- tsx prisma/seed.ts",
    "db:validate": "dotenv -e ../../.env -- prisma validate",
    "db:format": "dotenv -e ../../.env -- prisma format"
  },
  "dependencies": {
    "@prisma/client": "^5.7.1",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "dotenv-cli": "^11.0.0",
    "prisma": "^5.7.1",
    "prisma-erd-generator": "^2.0.4",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
