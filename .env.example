# Skopíruj na `.env` a doplň vlastné hodnoty.

# JWT
JWT_SECRET="CHANGE_ME"
JWT_EXPIRES_IN="7d"

# Database (pooled pre API, direct pre migrácie)
# Súbor nechaj v koreni monorepa; npm skripty v packages/database ho načítajú cez dotenv-cli.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?sslmode=require&connection_limit=5"
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?sslmode=require"

# API
PORT=3001
FRONTEND_URL="http://localhost:3000"

# Next.js Public API URL
NEXT_PUBLIC_API_URL="http://localhost:3001"

