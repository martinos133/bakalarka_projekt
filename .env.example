# Skopíruj na `.env` a doplň vlastné hodnoty.

# JWT
JWT_SECRET="CHANGE_ME"
JWT_EXPIRES_IN="7d"

# Database — stačí jedna URL (lokálny Postgres, Docker…)
# Súbor nechaj v koreni monorepa; Prisma / API ho načítavajú odtiaľ.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?sslmode=prefer"
# Voliteľné: pri Neon/Supabase s PgBouncerom nastav priamy connection string pre migrácie
# a v prisma/schema.prisma odkomentuj `directUrl = env("DIRECT_DATABASE_URL")`.
# DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?sslmode=require"

# API
PORT=3001
FRONTEND_URL="http://localhost:3000"

# Next.js Public API URL
NEXT_PUBLIC_API_URL="http://localhost:3001"

